<?xml version="1.0" encoding="utf-8"?>
<!--
  Covault status bar / notification small icon.

  Android status bar icons MUST be:
    - 24x24dp viewport
    - Monochrome (single color: #FFFFFF) — the system tints them
      with the notification's iconColor at runtime
    - All non-transparent pixels use #FFFFFF
    - Keep key strokes within the inner 18dp safe zone — anything
      outside gets clipped by the status bar / launcher mask
    - Drawn as filled shapes/strokes; do not rely on color to
      convey meaning

  This icon mirrors the adaptive launcher icon: a rounded vault
  door with a centered dial and a small handle. White only,
  no fills other than #FFFFFF.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Vault door: rounded rectangle outline -->
    <!-- Outer shape (white) with a transparent inner rectangle = the "door" stroke -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M6,6 L16,6 A3,3 0 0 1 19,9 L19,15 A3,3 0 0 1 16,18 L6,18 A3,3 0 0 1 3,15 L3,9 A3,3 0 0 1 6,6 Z M6,8 A1,1 0 0 0 5,9 L5,15 A1,1 0 0 0 6,16 L16,16 A1,1 0 0 0 17,15 L17,9 A1,1 0 0 0 16,8 Z" />

    <!-- Dial circle (centered at 11,12), white ring -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M11,8.5 A3.5,3.5 0 1 1 11,15.5 A3.5,3.5 0 1 1 11,8.5 Z M11,10 A2,2 0 1 0 11,14 A2,2 0 1 0 11,10 Z" />

    <!-- Handle: small notch at lower-right of the dial -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M11,12 L13.5,14.5 L12.95,15.05 L10.45,12.55 Z" />
</vector>
