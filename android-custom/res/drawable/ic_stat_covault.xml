<?xml version="1.0" encoding="utf-8"?>
<!--
  Covault status bar / notification small icon.

  Android status bar icons MUST be:
    - 24x24dp viewport
    - Monochrome (single color: #FFFFFF) — the system tints them
      with the notification's iconColor at runtime
    - All non-transparent pixels use #FFFFFF
    - Key strokes kept within the inner 18dp safe zone so the
      status-bar mask doesn't clip them
    - Drawn as filled shapes / strokes; do not rely on color to
      convey meaning

  This icon mirrors the adaptive launcher icon
  (ic_covault_foreground.xml) at status-bar scale: rounded vault
  door + centered dial + diagonal handle. The four compass-point
  spokes from the launcher are intentionally omitted — at 24dp they
  would render as sub-pixel artefacts.

  iOS is unaffected — smallIcon is an Android-only field.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Vault door: rounded rectangle outline (centered, 18dp safe zone).
         Outer 12x9 box at 6,7.5 with 1.5dp corner radius, with a 0.75dp
         white stroke (rendered as outer + inner even-odd path). -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M7.5,7.5 L16.5,7.5 A1,1 0 0 1 17.5,8.5 L17.5,15.5 A1,1 0 0 1 16.5,16.5 L7.5,16.5 A1,1 0 0 1 6.5,15.5 L6.5,8.5 A1,1 0 0 1 7.5,7.5 Z M8.25,8.5 L8.25,15.5 L15.75,15.5 L15.75,8.5 Z" />

    <!-- Dial circle (centered at 12,12) — outer ring minus inner disk -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,9.5 A2.5,2.5 0 1 1 12,14.5 A2.5,2.5 0 1 1 12,9.5 Z M12,10.5 A1.5,1.5 0 1 0 12,13.5 A1.5,1.5 0 1 0 12,10.5 Z" />

    <!-- Diagonal handle -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,12 L13.3,13.3 L12.95,13.65 L11.65,12.35 Z" />
</vector>
