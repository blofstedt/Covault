<?xml version="1.0" encoding="utf-8"?>
<!--
  Covault status bar / notification small icon — MONOCHROME variant.

  Android status bar icons MUST be:
    - 24x24dp viewport
    - Monochrome (single color: #FFFFFF) — the system tints them
      with the notification's iconColor at runtime
    - All non-transparent pixels use #FFFFFF
    - Key strokes kept within the inner 18dp safe zone so the
      status-bar mask doesn't clip them
    - Drawn as filled shapes / strokes; do not rely on color to
      convey meaning

  Same brand mark as the launcher icon (vault door + dial + handle)
  but simplified for 24dp status bar rendering. iOS is unaffected
  (smallIcon is an Android-only field).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Vault door: rounded square outline.
         Outer filled rect with transparent inner rect = a white stroke. -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M5,3 L19,3 A2,2 0 0 1 21,5 L21,19 A2,2 0 0 1 19,21 L5,21 A2,2 0 0 1 3,19 L3,5 A2,2 0 0 1 5,3 Z M5,4.5 L5,19.5 L19,19.5 L19,4.5 Z" />

    <!-- Centered dial ring. -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M12,7.5 A4.5,4.5 0 1 1 12,16.5 A4.5,4.5 0 1 1 12,7.5 Z M12,9 A3,3 0 1 0 12,15 A3,3 0 1 0 12,9 Z" />

    <!-- Diagonal handle, scaled to match the new dial size. -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M11,11.2 L12.8,11.2 L15.8,14.2 L14,16 Z" />
</vector>
