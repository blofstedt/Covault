# Supabase Configuration
# Get these from your Supabase project: https://app.supabase.com/project/_/settings/api
# Use VITE_SUPABASE_URL for GitHub Actions/Android or VITE_PUBLIC_SUPABASE_URL for Vercel
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# (Removed: VITE_RESEND_API_KEY and VITE_SENDER_EMAIL were used by
#  the send-report Edge Function, which has been removed from the
#  repo because nothing called it. If you re-add server-side email
#  sending, redeploy the Edge Function and add a server-side
#  RESEND_API_KEY secret instead of putting it in the client bundle.)

# IMPORTANT: After setting up your .env file:
# 1. In Supabase Dashboard, go to Authentication > URL Configuration > Redirect URLs
# 2. Add these URLs:
#    - For web: https://your-domain.com (or http://localhost:3000 for dev)
#    - For Android: com.covault.app://auth/callback
# 3. In Google Cloud Console OAuth 2.0 Client, add authorized redirect URIs:
#    - Your Supabase callback URL: https://your-project-id.supabase.co/auth/v1/callback
