# Supabase Configuration
# Get these from your Supabase project: https://app.supabase.com/project/_/settings/api
# Use VITE_SUPABASE_URL for GitHub Actions/Android or VITE_PUBLIC_SUPABASE_URL for Vercel
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Gemini API for AI features
GEMINI_API_KEY=your-gemini-api-key-here

# Resend API key for sending report emails
# Get yours at https://resend.com/api-keys
# The app tries the Supabase Edge Function first; if that fails it uses this key directly.
# ⚠️  For production, deploy the Supabase Edge Function and set RESEND_API_KEY
#    as a server-side secret instead (keeps the key private).
VITE_RESEND_API_KEY=re_your-resend-api-key-here

# Optional: Custom sender email (must be verified in Resend)
# VITE_SENDER_EMAIL=Covault Reports <reports@yourdomain.com>

# IMPORTANT: After setting up your .env file:
# 1. In Supabase Dashboard, go to Authentication > URL Configuration > Redirect URLs
# 2. Add these URLs:
#    - For web: https://your-domain.com (or http://localhost:3000 for dev)
#    - For Android: com.covault.app://auth/callback
# 3. In Google Cloud Console OAuth 2.0 Client, add authorized redirect URIs:
#    - Your Supabase callback URL: https://your-project-id.supabase.co/auth/v1/callback
