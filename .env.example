# Supabase Configuration
# Get these from your Supabase project: https://app.supabase.com/project/_/settings/api
VITE_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Gemini API for AI features
GEMINI_API_KEY=your-gemini-api-key-here

# IMPORTANT: After setting up your .env file:
# 1. In Supabase Dashboard, go to Authentication > URL Configuration > Redirect URLs
# 2. Add these URLs:
#    - For web: https://your-domain.com (or http://localhost:3000 for dev)
#    - For Android: com.covault.app://auth/callback
# 3. In Google Cloud Console OAuth 2.0 Client, add authorized redirect URIs:
#    - Your Supabase callback URL: https://your-project-id.supabase.co/auth/v1/callback
